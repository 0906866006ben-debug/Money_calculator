<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_widget"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_widget"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:name=".WidgetConfigActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".RiskWidgetProvider"
            android:exported="true"
            android:label="@string/widget_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.moneycalculator.widget.ACTION_DECREASE_STOP" />
                <action android:name="com.moneycalculator.widget.ACTION_INCREASE_STOP" />
                <action android:name="com.moneycalculator.widget.ACTION_DECREASE_STOP_FAST" />
                <action android:name="com.moneycalculator.widget.ACTION_INCREASE_STOP_FAST" />
            </intent-filter>

            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/risk_widget_info" />
        </receiver>
    </application>

</manifest>
